# Đổi tên file này thành .env rồi điền thông tin

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tên công ty hiển thị trong câu trả lời
COMPANY_NAME=Lotte World Aquarium Hanoi

# Model LLM: gpt-4o-mini (rẻ) hoặc gpt-4o (chính xác hơn)
LLM_MODEL=gpt-4o-mini

# Số lượng chunks lấy ra để trả lời (5-8 là hợp lý)
TOP_K=5
