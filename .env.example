# .env.example (full set after all phases)

# OpenAI
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small    # or text-embedding-3-large
CHAT_MODEL=gpt-4o-mini                    # or gpt-4o

# Admin Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
JWT_SECRET=your-secret-key

# Retrieval tuning (server-optimized defaults)
TOP_K=5                   # final results returned to LLM context
TOP_K_DENSE=20            # larger candidate pool vs low-RAM devices
TOP_K_BM25=20
TOP_K_RERANK=10           # candidates passed to cross-encoder

# Reranker (local CPU model — x86_64)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Alternative Vietnamese-tuned model:
# RERANKER_MODEL=itdainb/PhoRanker

# Qdrant
QDRANT_URL=http://qdrant:6333

# HuggingFace cache (point to large disk partition)
HF_HOME=/opt/rag_journey/data/hf_cache
# HF_TOKEN=hf_...         # only needed for private datasets

# Ingestion
INGEST_BATCH_SIZE=512     # chunks per OpenAI embedding call
